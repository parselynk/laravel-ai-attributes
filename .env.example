# Copy this file to `.env` and fill in your real keys.
# .env is gitignored and never leaves your machine.
#
# This package delegates to laravel/ai — set provider API keys there.

# --- laravel/ai providers (see config/ai.php) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Ollama (local, no key needed) ---
# OLLAMA_URL=http://localhost:11434

# --- laravel-ai-attributes defaults ---
# Which provider to use if an attribute doesn't specify one (must match config/ai.php)
AI_ATTRIBUTES_PROVIDER=openai

# Cache tuning
AI_ATTRIBUTES_CACHE_ENABLED=true
AI_ATTRIBUTES_CACHE_TTL=2592000
